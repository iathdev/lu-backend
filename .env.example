APP_PORT=8001
SERVICE_NAME=learning-ultility

GIN_MODE=release

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=learning_ultility
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m

PREP_API_GATEWAY_DOMAIN=

CB_MAX_REQUESTS=5
CB_INTERVAL=60s
CB_TIMEOUT=30s
CB_FAILURE_RATIO=0.6
CB_MIN_REQUESTS=10

LOG_LEVEL=info
LOG_FORMAT=json
LOG_CHANNELS=console

OTLP_ENDPOINT=
OTLP_INSECURE=true

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=1.0

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
