APP_PORT=8001
SERVICE_NAME=learning-ultility

GIN_MODE=release

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=learning_ultility
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m

PREP_API_DOMAIN=

CB_MAX_REQUESTS=5
CB_INTERVAL=60s
CB_TIMEOUT=30s
CB_FAILURE_RATIO=0.6
CB_MIN_REQUESTS=10

LOG_LEVEL=info
LOG_FORMAT=text
LOG_CHANNELS=console

OTLP_ENDPOINT=
OTLP_INSECURE=true

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=1.0

# OCR Service (Python PaddleOCR wrapper). See scripts/ocr-service/README.md
OCR_SERVICE_URL=http://localhost:8000

GOOGLE_APPLICATION_CREDENTIALS=

# Baidu OCR API (handwritten Chinese)
# Setup: https://console.bce.baidu.com/ → 文字识别 → 创建应用
# Leave empty to skip Baidu (PaddleOCR/Google Vision remain as fallback)
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
